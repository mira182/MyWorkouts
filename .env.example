# Copy this file to ".env" next to docker-compose.yaml and fill in real values.
# ".env" is git-ignored — never commit real secrets.

# --- Database -----------------------------------------------------------
# Drive the dedicated myworkouts-postgres container and the backend datasource.
DB_NAME=my_workouts
DB_USER=webappuser
DB_PASSWORD=change-me

# --- Auth ---------------------------------------------------------------
# JWT signing secret — a long random string. Tokens are signed/verified with this,
# so a weak/guessable value lets anyone forge valid logins. Generate e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# --- CORS ---------------------------------------------------------------
# Every browser origin that may call the API (comma-separated).
APP_CORS_ALLOWED_ORIGINS=http://192.168.100.232:8082,https://workouts.mira182.synology.me

# --- Withings OAuth -----------------------------------------------------
WITHINGS_CLIENT_ID=change-me
WITHINGS_CLIENT_SECRET=change-me
# Must be HTTPS and registered in the Withings developer console
WITHINGS_REDIRECT_URI=https://workouts.mira182.synology.me/weight
